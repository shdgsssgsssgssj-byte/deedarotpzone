# IVAS Cookies - Copy from browser Network tab
# Format: XSRF-TOKEN=value; ivas_session=value
IVAS_COOKIES="XSRF-%3D; ivas_session=YOUR_SESSION_VALUE_HERE"

# Optional: Custom API endpoint
# IVAS_API_URL=https://www.ivasms.com/api/v1/fetch-data

# Optional: Retry settings
# RETRY_COUNT=3
# RETRY_DELAY=2000
# TIMEOUT=30000
